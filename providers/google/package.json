{
  "name": "@kortyx/google",
  "version": "0.3.0",
  "private": false,
  "description": "Google Gemini provider integration for Kortyx.",
  "keywords": [
    "ai",
    "agent",
    "providers",
    "google",
    "gemini",
    "kortyx"
  ],
  "license": "Apache-2.0",
  "homepage": "https://kortyx.io/",
  "bugs": {
    "url": "https://github.com/kortyx-io/kortyx/issues"
  },
  "author": "Kortyx (https://github.com/kortyx-io)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsc --watch",
    "lint": "biome check src",
    "test": "vitest run && pnpm -s type-check",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@kortyx/providers": "workspace:*"
  },
  "devDependencies": {
    "turbo": "catalog:",
    "typescript": "catalog:",
    "tsup": "catalog:",
    "vitest": "catalog:"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/kortyx-io/kortyx.git",
    "directory": "providers/google"
  },
  "publishConfig": {
    "access": "public"
  }
}
