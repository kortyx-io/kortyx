{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "../..",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "incremental": false
  },
  "include": [
    "src/**/*",
    "test/**/*",
    "../../packages/providers/src/**/*",
    "../../packages/providers/test/**/*"
  ],
  "exclude": ["node_modules", "dist", "coverage"]
}
