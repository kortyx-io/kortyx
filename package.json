{
  "name": "kortyx-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Kortyx monorepo (AI agent orchestration framework).",
  "license": "Apache-2.0",
  "homepage": "https://github.com/kortyx-io/kortyx#readme",
  "bugs": {
    "url": "https://github.com/kortyx-io/kortyx/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kortyx-io/kortyx"
  },
  "packageManager": "pnpm@10.0.0+sha512.b8fef5494bd3fe4cbd4edabd0745df2ee5be3e4b0b8b08fa643aa3e4c6702ccc0f00d68fa8a8c9858a735a0032485a44990ed2810526c875e416f001b17df12b",
  "workspaces": [
    "apps/*",
    "examples/*",
    "packages/*",
    "providers/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo run build --filter=kortyx --filter=@kortyx/google && dotenv -e .env -- turbo run dev --concurrency=20 --continue=dependencies-successful --filter=!@kortyx/example-nextjs-chat-server-action",
    "dev:all": "dotenv -e .env -- turbo run dev --parallel --concurrency=20 --continue=dependencies-successful",
    "lint": "biome check .",
    "test": "turbo run test",
    "type-check": "turbo type-check",
    "type-check:watch": "turbo type-check --watch",
    "start": "turbo start",
    "clean": "rm -rf .turbo && rm -rf apps/**/.next apps/**/dist packages/**/dist providers/**/dist && find . -name '*.tsbuildinfo' -delete",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "prepare": "command -v husky >/dev/null 2>&1 && husky || echo 'Husky not available, skipping'"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.4",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@types/node": "catalog:",
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.5",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css}": [
      "biome check --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "ajv": "8.18.0",
      "langsmith": "0.5.4",
      "postcss": "8.5.8",
      "rollup": "4.59.0",
      "terser-webpack-plugin": "5.4.0",
      "vite": "8.0.0"
    }
  }
}
