{
  "name": "@kortyx/mcp",
  "version": "0.1.0",
  "private": false,
  "description": "MCP client tools for Kortyx.",
  "keywords": [
    "ai",
    "agent",
    "agents",
    "mcp",
    "model-context-protocol",
    "tools",
    "kortyx"
  ],
  "license": "Apache-2.0",
  "homepage": "https://kortyx.io/",
  "bugs": {
    "url": "https://github.com/kortyx-io/kortyx/issues"
  },
  "author": "Kortyx (https://github.com/kortyx-io)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "predev": "tsc -p tsconfig.build.json",
    "dev": "tsc --watch",
    "lint": "biome check src test",
    "test": "vitest run --passWithNoTests && pnpm -s type-check",
    "coverage": "vitest run --coverage --passWithNoTests && pnpm -s type-check",
    "type-check": "tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@kortyx/providers": "workspace:*",
    "@modelcontextprotocol/sdk": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "tsup": "catalog:",
    "vitest": "catalog:"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/kortyx-io/kortyx.git",
    "directory": "packages/mcp"
  },
  "publishConfig": {
    "access": "public"
  }
}
