      "component": "example-nextjs-chat-api-route"
    },
    "examples/kortyx-nextjs-chat-server-action": {
      "package-name": "@kortyx/example-nextjs-chat-server-action",
      "component": "example-nextjs-chat-server-action"
    }
  }
}
