{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "bump-minor-pre-major": true,
  "include-component-in-tag": true,
  "separate-pull-requests": false,
  "plugins": [
    {
      "type": "node-workspace"
    }
  ],
  "packages": {
    "packages/agent": {
      "package-name": "@kortyx/agent",
      "component": "agent"
    },
    "packages/cli": {
      "package-name": "@kortyx/cli",
      "component": "cli"
    },
    "packages/core": {
      "package-name": "@kortyx/core",
      "component": "core"
    },
    "packages/hooks": {
      "package-name": "@kortyx/hooks",
      "component": "hooks"
    },
    "packages/react": {
      "package-name": "@kortyx/react",
      "component": "react"
    },
    "packages/kortyx": {
      "package-name": "kortyx",
      "component": "kortyx"
    },
    "packages/providers": {
      "package-name": "@kortyx/providers",
      "component": "providers"
    },
    "providers/deepseek": {
      "package-name": "@kortyx/deepseek",
      "component": "deepseek"
    },
    "providers/groq": {
      "package-name": "@kortyx/groq",
      "component": "groq"
    },
    "providers/openai": {
      "package-name": "@kortyx/openai",
      "component": "openai"
    },
    "providers/anthropic": {
      "package-name": "@kortyx/anthropic",
      "component": "anthropic"
    },
    "providers/google": {
      "package-name": "@kortyx/google",
      "component": "google"
    },
    "packages/runtime": {
      "package-name": "@kortyx/runtime",
      "component": "runtime"
    },
    "packages/stream": {
      "package-name": "@kortyx/stream",
      "component": "stream"
    },
    "packages/utils": {
      "package-name": "@kortyx/utils",
      "component": "utils"
    },
    "apps/website": {
      "package-name": "kortyx-website",
      "component": "website"
    },
    "examples/kortyx-nextjs-chat-api-route": {
      "package-name": "@kortyx/example-nextjs-chat-api-route",
      "component": "example-nextjs-chat-api-route"
    },
    "examples/kortyx-nextjs-chat-server-action": {
      "package-name": "@kortyx/example-nextjs-chat-server-action",
      "component": "example-nextjs-chat-server-action"
    }
  }
}
