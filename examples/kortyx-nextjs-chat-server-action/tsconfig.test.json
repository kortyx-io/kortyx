{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": false
  },
  "include": [
    ".next/types/**/*.ts",
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "test/**/*.ts",
    "test/**/*.tsx",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "dist/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "scripts",
    "webpack.embed.config.js",
    "public",
    "**/embed.js"
  ]
}
