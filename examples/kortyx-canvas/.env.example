#
# Copy to .env.local for Next.js
#

# LLM provider
GOOGLE_API_KEY=

# Local dev port used by package.json
KORTYX_CANVAS_PORT=3002

# Framework persistence (interrupt/resume checkpoints + pending requests)
KORTYX_REDIS_URL=redis://127.0.0.1:6379

# Optional: TTL for framework persistence (milliseconds)
KORTYX_FRAMEWORK_TTL_MS=900000
