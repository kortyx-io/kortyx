#
# Copy to .env.local for Next.js
#

# LLM provider
GOOGLE_API_KEY=

# Optional MCP demo endpoint for the mcp-lorem-demo workflow.
# Defaults to the public no-auth Arcade demo server.
KORTYX_EXAMPLE_MCP_URL=https://mcp-http-demo.arcade.dev/mcp

# Framework persistence (interrupt/resume checkpoints + pending requests)
# Use Redis in production (or for testing restart-resume locally).
KORTYX_REDIS_URL=redis://127.0.0.1:6379

# Optional: TTL for framework persistence (milliseconds)
KORTYX_FRAMEWORK_TTL_MS=900000
