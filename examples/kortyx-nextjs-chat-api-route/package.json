{
  "name": "@kortyx/example-nextjs-chat-api-route",
  "version": "0.11.0",
  "private": true,
  "description": "Kortyx example: Next.js chat app (API route method).",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "next dev --turbopack --port ${KORTYX_NEXTJS_CHAT_PORT:-3000}",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "biome check .",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "redis:up": "docker rm -f kortyx-redis >/dev/null 2>&1 || true && docker run -d --name kortyx-redis -p ${KORTYX_REDIS_PORT:-6379}:6379 redis:7-alpine",
    "redis:down": "docker rm -f kortyx-redis",
    "redis:logs": "docker logs -f kortyx-redis",
    "redis:cli": "redis-cli -h 127.0.0.1 -p ${KORTYX_REDIS_PORT:-6379}",
    "test": "vitest run --passWithNoTests && pnpm -s type-check",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@kortyx/google": "workspace:*",
    "@kortyx/react": "workspace:*",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "catalog:",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "ai": "5.0.123",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "framer-motion": "^12.23.19",
    "kortyx": "workspace:*",
    "lucide-react": "catalog:",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-markdown": "catalog:",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "catalog:",
    "shiki": "^3.21.0",
    "tailwind-merge": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.23.0",
    "@babel/preset-typescript": "^7.23.0",
    "@tailwindcss/postcss": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "autoprefixer": "^10.4.0",
    "babel-loader": "^9.1.0",
    "css-loader": "^6.8.0",
    "dotenv": "^17.2.1",
    "postcss": "^8.5.8",
    "postcss-loader": "^7.3.0",
    "tailwindcss": "catalog:",
    "ts-loader": "^9.5.0",
    "tw-animate-css": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "webpack": "^5.105.4",
    "webpack-cli": "^5.1.0"
  },
  "homepage": "https://kortyx.io/",
  "bugs": {
    "url": "https://github.com/kortyx-io/kortyx/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kortyx-io/kortyx.git"
  }
}
